{
  "name": "jellyfin-mcp",
  "version": "0.4.0",
  "description": "MCP server for Jellyfin media server: control sessions, scan libraries, manage users, query content, manage resume state, and run scheduled tasks via LLM tool calls",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "jellyfin-mcp": "dist/mcp-bin.js",
    "jellyctl": "dist/cli.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx watch src/index.ts",
    "start": "node dist/cli.js mcp",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "tsc --noEmit",
    "prepublishOnly": "npm test && npm run build",
    "typecheck": "tsc --noEmit"
  },
  "author": "Solomon Neas <me@solomonneas.dev>",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lidless-labs/jellyfin-mcp.git"
  },
  "homepage": "https://github.com/lidless-labs/jellyfin-mcp#readme",
  "bugs": {
    "url": "https://github.com/lidless-labs/jellyfin-mcp/issues"
  },
  "keywords": [
    "mcp",
    "jellyfin",
    "media-server",
    "model-context-protocol",
    "llm-tools",
    "claude",
    "home-media"
  ],
  "engines": {
    "node": ">=20.0.0"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "undici": "^7.27.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.6.0",
    "tsup": "^8.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ]
}
